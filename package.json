{
  "name": "heybox-forum",
  "displayName": "HeyBox Forum",
  "description": "在 VSCode 中浏览小黑盒论坛帖子和评论，支持隐身模式",
  "version": "0.1.4",
  "publisher": "kyo",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:heybox.postList"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "heybox",
          "title": "HeyBox",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "heybox": [
        {
          "id": "heybox.postList",
          "name": "帖子列表"
        },
        {
          "id": "heybox.postDetail",
          "name": "帖子详情",
          "type": "webview"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "heybox.searchPost",
          "when": "view == heybox.postList || view == heybox.postDetail",
          "group": "navigation"
        },
        {
          "command": "heybox.refreshList",
          "when": "view == heybox.postList || view == heybox.postDetail",
          "group": "navigation"
        },
        {
          "command": "heybox.signDaily",
          "when": "view == heybox.postList",
          "group": "navigation"
        },
        {
          "command": "heybox.toggleNotifications",
          "when": "view == heybox.postList",
          "group": "navigation"
        },
        {
          "command": "heybox.markAllRead",
          "when": "view == heybox.postList",
          "group": "navigation"
        },
        {
          "command": "heybox.login",
          "when": "view == heybox.postList",
          "group": "navigation"
        },
        {
          "command": "heybox.logout",
          "when": "view == heybox.postList",
          "group": "navigation"
        },
        {
          "command": "heybox.switchTheme",
          "when": "view == heybox.postList",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "heybox.openInBrowser",
          "when": "viewItem == post",
          "group": "0_inline"
        },
        {
          "command": "heybox.toggleFavourite",
          "when": "viewItem == post",
          "group": "0_inline"
        }
      ]
    },
    "commands": [
      {
        "command": "heybox.openPost",
        "title": "打开帖子",
        "category": "HeyBox"
      },
      {
        "command": "heybox.searchPost",
        "title": "搜索帖子",
        "icon": "$(search)",
        "category": "HeyBox"
      },
      {
        "command": "heybox.exitSearch",
        "title": "返回话题列表",
        "category": "HeyBox"
      },
      {
        "command": "heybox.switchToRecommend",
        "title": "切换到推荐",
        "category": "HeyBox"
      },
      {
        "command": "heybox.switchToCategories",
        "title": "切换到板块",
        "category": "HeyBox"
      },
      {
        "command": "heybox.switchToFavorites",
        "title": "切换到收藏",
        "category": "HeyBox"
      },
      {
        "command": "heybox.loadMoreSearch",
        "title": "加载更多搜索结果",
        "category": "HeyBox"
      },
      {
        "command": "heybox.loadMoreFeed",
        "title": "加载更多推荐",
        "category": "HeyBox"
      },
      {
        "command": "heybox.refreshList",
        "title": "刷新列表",
        "icon": "$(refresh)",
        "category": "HeyBox"
      },
      {
        "command": "heybox.signDaily",
        "title": "每日签到",
        "icon": "$(check)",
        "category": "HeyBox"
      },
      {
        "command": "heybox.toggleNotifications",
        "title": "切换消息提醒",
        "icon": "$(bell)",
        "category": "HeyBox"
      },
      {
        "command": "heybox.markAllRead",
        "title": "标记所有消息为已读",
        "icon": "$(check-all)",
        "category": "HeyBox"
      },
      {
        "command": "heybox.openByUrl",
        "title": "通过URL打开帖子",
        "category": "HeyBox"
      },
      {
        "command": "heybox.openInBrowser",
        "title": "在浏览器中打开",
        "category": "HeyBox"
      },
      {
        "command": "heybox.toggleFavourite",
        "title": "收藏/取消收藏",
        "category": "HeyBox"
      },
      {
        "command": "heybox.loadMore",
        "title": "加载更多",
        "category": "HeyBox"
      },
      {
        "command": "heybox.toggleSidebar",
        "title": "切换侧边栏",
        "category": "HeyBox"
      },
      {
        "command": "heybox.openClipboardUrl",
        "title": "从剪贴板URL打开帖子",
        "category": "HeyBox"
      },
      {
        "command": "heybox.login",
        "title": "登录",
        "icon": "$(sign-in)",
        "category": "HeyBox"
      },
      {
        "command": "heybox.logout",
        "title": "退出登录",
        "icon": "$(sign-out)",
        "category": "HeyBox"
      },
      {
        "command": "heybox.switchTheme",
        "title": "切换主题",
        "icon": "$(symbol-color)",
        "category": "HeyBox"
      }
    ],
    "keybindings": [
      {
        "command": "heybox.toggleSidebar",
        "key": "ctrl+shift+j",
        "mac": "cmd+shift+j"
      },
      {
        "command": "heybox.toggleSidebar",
        "key": "alt+h",
        "mac": "alt+h"
      },
      {
        "command": "heybox.openClipboardUrl",
        "key": "ctrl+shift+enter",
        "mac": "cmd+shift+enter"
      }
    ],
    "walkthroughs": {
      "start": [
        {
          "id": "heybox.walkthrough",
          "title": "🐟 开始使用 HeyBox Forum",
          "description": "三步完成配置",
          "steps": [
            {
              "id": "setupCookie",
              "title": "1️⃣ 配置 Cookie",
              "description": "点击打开设置，搜索 ``heybox.cookie`` 并粘贴从小黑盒网站复制的 Cookie 值。\n\n**如何获取 Cookie？**\n1. 打开浏览器访问 xiaoheihe.cn 并登录\n2. 按 F12 → Network → 刷新页面\n3. 复制任意请求的 Cookie 头",
              "completionEvents": [
                "onSettingChanged:heybox.cookie"
              ],
              "media": {
                "markdown": "resources/walkthrough-cookie.md"
              }
            },
            {
              "id": "browse",
              "title": "2️⃣ 浏览帖子",
              "description": "点击侧边栏 HeyBox 图标，展开话题查看帖子列表，或点击 🔍 搜索。点击帖子查看详情。",
              "completionEvents": [
                "onCommand:heybox.openPost"
              ],
              "media": {
                "markdown": "resources/walkthrough-browse.md"
              }
            },
            {
              "id": "stealth",
              "title": "3️⃣ 开启隐身模式",
              "description": "设置 ``heybox.stealthMode: true``，界面伪装为代码片段，适合办公环境。",
              "completionEvents": [
                "onSettingChanged:heybox.stealthMode"
              ],
              "media": {
                "markdown": "resources/walkthrough-stealth.md"
              }
            }
          ]
        }
      ]
    },
    "configuration": {
      "title": "HeyBox Forum",
      "properties": {
        "heybox.cookie": {
          "type": "string",
          "default": "",
          "description": "小黑盒网站 Cookie（从浏览器开发者工具复制完整的 Cookie 头值）"
        },
        "heybox.deviceId": {
          "type": "string",
          "default": "",
          "description": "设备 ID（留空则自动生成并持久化）"
        },
        "heybox.heyboxId": {
          "type": "string",
          "default": "",
          "description": "小黑盒用户 ID（可留空，从 cookie 中自动提取）"
        },
        "heybox.stealthMode": {
          "type": "boolean",
          "default": false,
          "description": "隐身模式：将界面名称伪装为代码片段，Webview 标题显示为 README.md"
        },
        "heybox.minimalMode": {
          "type": "boolean",
          "default": false,
          "description": "简约模式：隐藏点赞/评论等社交数据，仅显示标题"
        },
        "heybox.postDetailLocation": {
          "type": "string",
          "default": "sidebar",
          "enum": [
            "sidebar",
            "editor",
            "beside"
          ],
          "enumDescriptions": [
            "在侧边栏/面板区域显示",
            "在编辑区显示",
            "在编辑区侧边显示"
          ],
          "description": "帖子详情显示位置"
        },
        "heybox.theme": {
          "type": "string",
          "default": "auto",
          "enum": [
            "auto",
            "dark",
            "light"
          ],
          "enumDescriptions": [
            "跟随 VSCode 主题",
            "强制暗色主题",
            "强制亮色主题"
          ],
          "description": "Webview 主题模式"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0"
  }
}
